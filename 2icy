        local p = Instance.new("Pants", char); p.PantsTemplate = "rbxassetid://" .. description.Pants
        
        local c = Instance.new("BodyColors", char)
        c.HeadColor3 = description.HeadColor
        c.LeftArmColor3 = description.LeftArmColor
        c.RightArmColor3 = description.RightArmColor
        c.LeftLegColor3 = description.LeftLegColor
        c.RightLegColor3 = description.RightLegColor
        c.TorsoColor3 = description.TorsoColor

        -- 5. APPLY SCALING
        hum.BodyHeightScale.Value = description.HeightScale
        hum.BodyWidthScale.Value = description.WidthScale
        hum.HeadScale.Value = description.HeadScale
    end)
end

local function applyheadless(char)
    if not cfg['headless']['enabled'] then return end
    if not char then return end

    local head = char:FindFirstChild("Head")
    if head then
        task.wait(0.5)
        head.Transparency = 1
        head.CanCollide = false
        local face = head:FindFirstChild("face")
        if face then
            face.Transparency = 1
        end
    end

    if cfg['headless']['remove face accessories'] then
        for _, accessory in ipairs(char:GetChildren()) do
            if accessory:IsA("Accessory") then
                if accessory.AccessoryType == Enum.AccessoryType.Face then
                    local handle = accessory:FindFirstChild("Handle")
                    if handle then
                        handle.Transparency = 1
                        handle.CanCollide = false
                    end
                end
            end
        end
    end

    char.ChildAdded:Connect(function(child)
        if not cfg['headless']['enabled'] then return end
        if child:IsA("Accessory") and child.AccessoryType == Enum.AccessoryType.Face then
            if not cfg['headless']['remove face accessories'] then return end
            local handle = child:FindFirstChild("Handle")
            if not handle then
                handle = child:WaitForChild("Handle", 5)
            end
            if handle then
                handle.Transparency = 1
                handle.CanCollide = false
            end
        end
    end)
end

