-- 2. The Metatable Hook (The "Magic" part)
-- This tricks the game into thinking your speed is 16 even when it's 32+
local mt = getrawmetatable(game)
local oldIndex = mt.__index
local oldNewIndex = mt.__newindex
setreadonly(mt, false)

mt.__index = newcclosure(function(t, k)
    if not checkcaller() and t:IsA("Humanoid") and k == "WalkSpeed" then
        return 16 -- Tell the game scripts your speed is always 16
    end
    return oldIndex(t, k)
end)

mt.__newindex = newcclosure(function(t, k, v)
    if not checkcaller() and t:IsA("Humanoid") and k == "WalkSpeed" then
        -- Prevent the game from changing your speed if toggle is on
        if speedToggle then return nil end 
    end
    return oldNewIndex(t, k, v)
end)
setreadonly(mt, true)

